<h1>Clubs</h1>

<% if current_club %>
  <section class="mb-6 p-4 rounded border border-teal-400 bg-black/50">
    <p class="mb-2"><strong>Modo:</strong> <%= current_game_mode == 'single' ? 'Un jugador' : 'Multijugador' %></p>
    <p class="mb-2"><strong>Club seleccionado:</strong> <%= link_to current_club.name, club_path(current_club) %></p>
    <p><%= link_to 'Cambiar modo o club', new_game_mode_path, class: 'underline text-amber' %></p>
  </section>
<% end %>

<% if @standings.any? %>
  <table>
    <thead>
      <tr>
        <th>Position</th>
        <th>Club</th>
        <th>Played</th>
        <th>Won</th>
        <th>Drawn</th>
        <th>Lost</th>
        <th>GF</th>
        <th>GA</th>
        <th>GD</th>
        <th>Points</th>
      </tr>
    </thead>
    <tbody>
      <% @standings.each do |standing| %>
        <tr>
          <td><%= standing.position %></td>
          <td><%= link_to standing.club_season.club.name, club_path(standing.club_season.club) %></td>
          <td><%= standing.played %></td>
          <td><%= standing.won %></td>
          <td><%= standing.drawn %></td>
          <td><%= standing.lost %></td>
          <td><%= standing.goals_for %></td>
          <td><%= standing.goals_against %></td>
          <td><%= standing.goal_difference %></td>
          <td><strong><%= standing.points %></strong></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p>No standings available.</p>
<% end %>
