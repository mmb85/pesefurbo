<%# app/views/matches/show.html.erb %>
<%# Tabs: Partido / Liga / Táctica — managed by navigation_controller.js %>
<% content_for :title, "#{@match.home_club.short_name} vs #{@match.away_club.short_name}" %>

<div class="win-desktop-area p-2 md:p-4"
     data-controller="navigation"
     data-navigation-active-value="partido">

  <%# ── TAB BAR ──────────────────────────────────────────────────────────── %>
  <div class="win-tabbar flex gap-0 mb-0">
    <button class="win-tab tab-active" data-tab="partido"
            data-navigation-target="tab"
            data-action="click->navigation#switch">
      📺 Partido
    </button>
    <button class="win-tab" data-tab="estadisticas"
            data-navigation-target="tab"
            data-action="click->navigation#switch">
      📊 Stats
    </button>
    <button class="win-tab" data-tab="alineaciones"
            data-navigation-target="tab"
            data-action="click->navigation#switch">
      👕 Alineaciones
    </button>
  </div>

  <%# ─────────────────────────────────────────────────────────────────────── %>
  <%# PANEL: PARTIDO %>
  <%# ─────────────────────────────────────────────────────────────────────── %>
  <div data-panel="partido" data-navigation-target="panel"
       data-controller="match-playback"
       data-match-playback-events-value="<%= @events_json %>"
       data-match-playback-interval-value="5000"
       data-match-playback-autoplay-value="<%= @match.simulated? %>">

    <%# SCOREBOARD %>
    <div class="win-panel mb-2" id="scoreboard">
      <div class="win-titlebar">
        <div class="win-titlebar-left">📺 PARTIDO EN CURSO · J.<%= @match.round %></div>
        <div class="win-btns"><span class="wbtn">_</span><span class="wbtn">□</span><span class="wbtn">✕</span></div>
      </div>
      <div class="p-3">
        <div class="scoreboard-inner">
          <div class="score-team text-center flex-1">
            <span class="text-3xl block">🔴</span>
            <span class="font-vt323 text-xl"><%= @match.home_club.short_name %></span>
          </div>
          <div class="score-mid text-center flex-shrink-0">
            <span class="score-digits font-pixel" id="sc-score">
              <span data-match-playback-target="homeScore"><%= @match.home_goals %></span>
              <span class="text-dim mx-2">–</span>
              <span data-match-playback-target="awayScore"><%= @match.away_goals %></span>
            </span>
            <span class="sc-min font-pixel text-red block mt-1 live"
                  data-match-playback-target="minute">0'</span>
            <span class="font-mono text-dim text-xs block mt-1">
              <%= @match.competition_season.competition.short_name %>
            </span>
          </div>
          <div class="score-team text-center flex-1">
            <span class="text-3xl block">🔵</span>
            <span class="font-vt323 text-xl"><%= @match.away_club.short_name %></span>
          </div>
        </div>

        <%# Zone indicator %>
        <div class="zone-bar mt-3" data-match-playback-target="zoneIndicator">
          <%= ["home_defense","home_midfield","home_attack","away_attack","away_midfield","away_defense"].map do |z| %>
            <span class="zone-seg" data-zone="<%= z %>">
              <%= z.gsub("home_","L.").gsub("away_","V.").gsub("_"," ").upcase %>
            </span>
          <% end.join.html_safe %>
        </div>
      </div>
    </div>

    <%# Half time / Final banners %>
    <div class="win-ht-banner hidden font-pixel text-amber text-center p-2 mb-2 border border-amber" id="ht-banner">
      ⏸ DESCANSO — PRIMER TIEMPO FINALIZADO
    </div>
    <div class="win-final-banner hidden mb-2" id="final-banner">
      <div class="font-pixel text-xs text-crt-green tracking-widest mb-2">⏱ PITIDO FINAL</div>
      <div class="font-pixel text-3xl text-amber" data-final-score>
        <%= @match.simulated? ? @match.score : "— – —" %>
      </div>
      <%= link_to "↩ Volver a partidos", matches_path, class: "btn-secondary mt-3 block text-center" %>
    </div>

    <%# Match stats bar %>
    <div class="win-stats-bar grid grid-cols-4 gap-0 mb-2 border border-border font-mono text-center">
      <div class="stat-cell border-r border-border">
        <span class="val text-amber"><%= @match.home_shots %>/<%= @match.away_shots %></span>
        <span class="lbl text-dim">TIROS</span>
      </div>
      <div class="stat-cell border-r border-border">
        <span class="val text-amber"><%= @match.home_shots_on %>/<%= @match.away_shots_on %></span>
        <span class="lbl text-dim">A PUERTA</span>
      </div>
      <div class="stat-cell border-r border-border">
        <span class="val text-amber"><%= @match.home_possession %>%/<%= @match.away_possession %>%</span>
        <span class="lbl text-dim">POSESIÓN</span>
      </div>
      <div class="stat-cell">
        <span class="val text-amber"><%= @match.home_yellow_cards %>/<%= @match.away_yellow_cards %></span>
        <span class="lbl text-dim">AMARILLAS</span>
      </div>
    </div>

    <%# NARRATION FEED %>
    <div class="win-panel mb-2">
      <div class="win-titlebar">
        <div class="win-titlebar-left">📻 NARRACIÓN EN DIRECTO</div>
      </div>
      <div class="narration-feed font-mono text-sm"
           data-match-playback-target="feed"
           style="height:280px;overflow-y:auto;padding:8px;background:#000;">
        <% if @match.simulated? %>
          <div class="ev-system nar-event">
            <span class="nar-min">0'</span>
            <span class="nar-text">Partido ya simulado. Reproduciendo retransmisión...</span>
          </div>
        <% else %>
          <div class="ev-system nar-event">
            <span class="nar-min">—</span>
            <span class="nar-text">Partido pendiente de simular.</span>
          </div>
        <% end %>
      </div>
      <div class="p-2 flex gap-2">
        <% if @match.status == "scheduled" %>
          <%= button_to "⚡ SIMULAR", simulate_match_path(@match),
            method: :post, class: "btn-primary flex-1" %>
        <% else %>
          <button class="btn-secondary flex-1"
                  data-action="click->match-playback#togglePause">
            ⏸ PAUSA
          </button>
          <button class="btn-secondary"
                  data-action="click->match-playback#skipToEnd">
            ⏩ FIN
          </button>
        <% end %>
        <%= link_to "↩ Partidos", matches_path, class: "btn-secondary" %>
      </div>
    </div>
  </div>

  <%# ─────────────────────────────────────────────────────────────────────── %>
  <%# PANEL: ESTADÍSTICAS %>
  <%# ─────────────────────────────────────────────────────────────────────── %>
  <div data-panel="estadisticas" data-navigation-target="panel" style="display:none;">
    <div class="win-panel">
      <div class="win-titlebar"><div class="win-titlebar-left">📊 ESTADÍSTICAS DEL PARTIDO</div></div>
      <div class="p-4 font-mono">
        <div class="stat-comparison-row">
          <span class="stat-home"><%= @match.home_shots %></span>
          <span class="stat-label">TIROS TOTALES</span>
          <span class="stat-away"><%= @match.away_shots %></span>
        </div>
        <div class="stat-comparison-row">
          <span class="stat-home"><%= @match.home_shots_on %></span>
          <span class="stat-label">A PUERTA</span>
          <span class="stat-away"><%= @match.away_shots_on %></span>
        </div>
        <div class="stat-comparison-row">
          <span class="stat-home"><%= @match.home_possession %>%</span>
          <span class="stat-label">POSESIÓN</span>
          <span class="stat-away"><%= @match.away_possession %>%</span>
        </div>
        <div class="stat-comparison-row">
          <span class="stat-home"><%= @match.home_corners %></span>
          <span class="stat-label">CÓRNERS</span>
          <span class="stat-away"><%= @match.away_corners %></span>
        </div>
        <div class="stat-comparison-row">
          <span class="stat-home text-amber"><%= @match.home_yellow_cards %></span>
          <span class="stat-label">AMARILLAS</span>
          <span class="stat-away text-amber"><%= @match.away_yellow_cards %></span>
        </div>
        <div class="stat-comparison-row">
          <span class="stat-home text-red-500"><%= @match.home_red_cards %></span>
          <span class="stat-label">ROJAS</span>
          <span class="stat-away text-red-500"><%= @match.away_red_cards %></span>
        </div>
      </div>
    </div>

    <%# Goals timeline %>
    <% goals = @match.match_events.goals.includes(:player).order(:minute) %>
    <% if goals.any? %>
      <div class="win-panel mt-2">
        <div class="win-titlebar"><div class="win-titlebar-left">⚽ GOLES</div></div>
        <div class="p-3">
          <% goals.each do |ev| %>
            <div class="goal-row flex items-center gap-3 py-2 border-b border-border font-mono text-sm">
              <span class="text-amber font-pixel text-xs w-10"><%= ev.display_minute %></span>
              <span class="text-crt-green">⚽</span>
              <span><%= ev.description&.truncate(80) %></span>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>

  <%# ─────────────────────────────────────────────────────────────────────── %>
  <%# PANEL: ALINEACIONES %>
  <%# ─────────────────────────────────────────────────────────────────────── %>
  <div data-panel="alineaciones" data-navigation-target="panel" style="display:none;">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
      <%# HOME lineup %>
      <div class="win-panel">
        <div class="win-titlebar" style="background: linear-gradient(90deg,#800010,#400010);">
          <div class="win-titlebar-left">👕 <%= @match.home_club.short_name %></div>
        </div>
        <div class="p-1">
          <% @home_lineup.each do |lineup| %>
            <div class="lineup-row <%= lineup.status == 'starter' ? 'starter' : 'bench' %>">
              <span class="sh-num"><%= lineup.shirt_number %></span>
              <span class="sh-name"><%= lineup.player.known_as %></span>
              <span class="sh-pos pos-<%= lineup.formation_position&.start_with?("G") ? "GK" :
                                            %w[CB LB RB SW].include?(lineup.formation_position) ? "DF" :
                                            %w[ST SS].include?(lineup.formation_position) ? "DL" : "MC" %>">
                <%= lineup.formation_position %>
              </span>
              <span class="sh-rating text-amber font-mono text-sm">
                <%= (lineup.rating.to_f / 10).round(1) %>
              </span>
            </div>
          <% end %>
        </div>
      </div>

      <%# AWAY lineup %>
      <div class="win-panel">
        <div class="win-titlebar" style="background: linear-gradient(90deg,#000080,#000040);">
          <div class="win-titlebar-left">👕 <%= @match.away_club.short_name %></div>
        </div>
        <div class="p-1">
          <% @away_lineup.each do |lineup| %>
            <div class="lineup-row <%= lineup.status == 'starter' ? 'starter' : 'bench' %>">
              <span class="sh-num"><%= lineup.shirt_number %></span>
              <span class="sh-name"><%= lineup.player.known_as %></span>
              <span class="sh-pos pos-<%= lineup.formation_position&.start_with?("G") ? "GK" :
                                            %w[CB LB RB SW].include?(lineup.formation_position) ? "DF" :
                                            %w[ST SS].include?(lineup.formation_position) ? "DL" : "MC" %>">
                <%= lineup.formation_position %>
              </span>
              <span class="sh-rating text-amber font-mono text-sm">
                <%= (lineup.rating.to_f / 10).round(1) %>
              </span>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>

</div><%# end win-desktop-area %>
