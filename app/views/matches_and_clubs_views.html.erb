<%# ============================================================================
    app/views/matches/index.html.erb
    ============================================================================ %>
<% content_for :title, "Partidos" %>

<div class="win-desktop-area app-content">

  <div class="win-panel">
    <div class="win-titlebar">
      <div class="win-titlebar-left">📅 CALENDARIO DE PARTIDOS</div>
      <div class="win-btns">
        <%= button_to "⚡ Simular todos", simulate_all_matches_path,
          method: :post,
          class: "btn-primary text-xs px-3 py-1",
          style: "font-size:12px;padding:3px 10px;" %>
      </div>
    </div>
    <div class="p-3">

      <% if @rounds.any? %>
        <% @rounds.each do |round, matches| %>
          <div class="mb-4">
            <div class="section-head mb-2">
              <span class="font-pixel text-xs text-amber">JORNADA <%= round %></span>
            </div>
            <% matches.each do |m| %>
              <%= link_to match_path(m), class: "match-row #{m.status == 'simulated' || m.status == 'finished' ? 'simulated' : ''}" do %>
                <span class="mrow-home"><%= m.home_club.short_name %></span>
                <span class="mrow-score">
                  <% if m.simulated? %>
                    <%= m.home_goals %>–<%= m.away_goals %>
                  <% else %>
                    vs
                  <% end %>
                </span>
                <span class="mrow-away"><%= m.away_club.short_name %></span>
                <span class="status-badge status-<%= m.status %>"><%= m.status.upcase %></span>
                <% if m.simulated? %>
                  <%= turbo_stream_from "match_#{m.id}_status" %>
                <% end %>
              <% end %>
            <% end %>
          </div>
        <% end %>
      <% else %>
        <p class="text-dim font-mono text-sm p-4">No hay partidos generados. Ejecuta <code>rails db:seed</code>.</p>
      <% end %>

    </div>
  </div>
</div>

<%# ============================================================================
    app/views/matches/_status_badge.html.erb
    ============================================================================ %>
<%# Partial rendered via Turbo Stream when job completes %>
<span id="match_status_<%= match.id %>" class="status-badge status-<%= match.status %>">
  <%= match.status.upcase %>
</span>

<%# ============================================================================
    app/views/clubs/index.html.erb  — Liga / standings
    ============================================================================ %>
<div class="win-desktop-area app-content">
  <div class="win-panel">
    <div class="win-titlebar">
      <div class="win-titlebar-left">🏆 CLASIFICACIÓN — <%= @competition_season&.competition&.name %></div>
    </div>
    <div class="p-2">

      <div class="mb-3 flex gap-6" style="font-family:'Share Tech Mono',monospace;font-size:11px;color:var(--dim);">
        <span style="border-left:3px solid var(--crt-green);padding-left:5px;">Champions League</span>
        <span style="border-left:3px solid var(--amber);padding-left:5px;">UEFA</span>
        <span style="border-left:3px solid var(--red);padding-left:5px;">Descenso</span>
      </div>

      <div style="overflow-x:auto;">
        <table class="liga-table">
          <thead>
            <tr>
              <th>#</th>
              <th>Equipo</th>
              <th>PJ</th>
              <th>G</th>
              <th>E</th>
              <th>P</th>
              <th>GF</th>
              <th>GC</th>
              <th>DG</th>
              <th>Pts</th>
            </tr>
          </thead>
          <tbody>
            <% @standings.each_with_index do |standing, idx| %>
              <%
                cs   = standing.club_season
                club = cs.club
                pos  = standing.position
                zone_class = if pos <= 1 then "zone-c"
                             elsif pos <= 4 then "zone-e"
                             elsif pos >= (@standings.size - 2) then "zone-r"
                             else "" end
              %>
              <tr class="<%= zone_class %> <%= club.is_player_club? ? 'my-club' : '' %>">
                <td><%= pos %></td>
                <td>
                  <%= link_to club_path(club), class: "text-inherit no-underline hover:text-crt-green" do %>
                    <%= club.abbr %>
                  <% end %>
                </td>
                <td><%= standing.played %></td>
                <td><%= standing.won %></td>
                <td><%= standing.drawn %></td>
                <td><%= standing.lost %></td>
                <td><%= standing.goals_for %></td>
                <td><%= standing.goals_against %></td>
                <td class="<%= standing.goal_difference >= 0 ? 'text-crt-green' : 'text-red' %>">
                  <%= standing.goal_difference > 0 ? "+#{standing.goal_difference}" : standing.goal_difference %>
                </td>
                <td class="pts"><%= standing.points %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

    </div>
  </div>
</div>

<%# ============================================================================
    app/views/clubs/show.html.erb
    ============================================================================ %>
<div class="win-desktop-area app-content">
  <div class="grid grid-cols-1 md:grid-cols-3 gap-3">

    <%# Club info panel %>
    <div class="win-panel md:col-span-1">
      <div class="win-titlebar">
        <div class="win-titlebar-left">🏟️ <%= @club.short_name %></div>
      </div>
      <div class="p-4">
        <div class="font-pixel text-xs text-amber mb-1"><%= @club.name %></div>
        <div class="font-mono text-xs text-dim mb-3">
          Fundado: <%= @club.founded_year || "—" %> · <%= @club.country.name %>
        </div>
        <% if @club.stadium %>
          <div class="font-mono text-sm mb-1">🏟️ <%= @club.stadium.name %></div>
          <div class="font-mono text-xs text-dim"><%= number_with_delimiter(@club.stadium.capacity) %> espectadores</div>
        <% end %>
        <% if @club_season %>
          <div class="mt-4 border-t border-border pt-3">
            <div class="font-mono text-xs text-dim mb-2">PRESUPUESTO</div>
            <div class="font-vt323 text-lg text-crt-green">
              <%= number_to_currency(@club_season.budget_total, unit: "€", precision: 0) %>
            </div>
          </div>
        <% end %>
      </div>
    </div>

    <%# Squad panel %>
    <div class="win-panel md:col-span-2">
      <div class="win-titlebar">
        <div class="win-titlebar-left">👕 PLANTILLA · <%= @club.short_name %></div>
      </div>
      <div class="p-1">
        <% @squad.each do |contract| %>
          <% p = contract.player %>
          <div class="squad-item">
            <span class="sh-num text-dim text-xs w-5 text-right">
              <%= contract.squad_number || "—" %>
            </span>
            <span class="flex-1 font-vt323 text-base"><%= p.known_as %></span>
            <span class="sh-pos pos-<%= p.position == 'GK' ? 'GK' :
              %w[CB LB RB SW].include?(p.position) ? 'DF' :
              %w[ST SS].include?(p.position) ? 'DL' : 'MC' %>">
              <%= p.position %>
            </span>
            <span class="text-amber font-mono text-sm"><%= p.overall_rating %></span>
            <% if contract.expiring_soon? %>
              <span class="text-red text-xs font-mono">⚠ <%= p.contracts.active.first.expires_on.strftime("%m/%y") %></span>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>

    <%# Tactic panel %>
    <% if @tactic %>
      <div class="win-panel md:col-span-1">
        <div class="win-titlebar"><div class="win-titlebar-left">⚙️ TÁCTICA</div></div>
        <div class="p-4 font-mono text-sm">
          <div class="mb-2">
            <span class="text-dim text-xs">FORMACIÓN</span>
            <span class="block text-amber font-pixel text-xs mt-1"><%= @tactic.formation %></span>
          </div>
          <div class="mb-2">
            <span class="text-dim text-xs">MENTALIDAD</span>
            <span class="block text-crt-green mt-1"><%= @tactic.mentality.upcase %></span>
          </div>
          <div class="mb-2">
            <span class="text-dim text-xs">PRESIÓN</span>
            <span class="block text-crt-green mt-1"><%= @tactic.pressing.upcase %></span>
          </div>
          <div class="mb-2">
            <span class="text-dim text-xs">JUEGO</span>
            <span class="block text-crt-green mt-1"><%= @tactic.passing_style.upcase %></span>
          </div>
        </div>
      </div>
    <% end %>

    <%# Recent results %>
    <div class="win-panel md:col-span-2">
      <div class="win-titlebar"><div class="win-titlebar-left">📊 ÚLTIMOS RESULTADOS</div></div>
      <div class="p-1">
        <% if @recent_matches.any? %>
          <% @recent_matches.each do |m| %>
            <% result = m.result_for(@club) %>
            <%= link_to match_path(m), class: "match-row" do %>
              <span class="mrow-home text-sm"><%= m.home_club.short_name %></span>
              <span class="mrow-score"><%= m.home_goals %>–<%= m.away_goals %></span>
              <span class="mrow-away text-sm"><%= m.away_club.short_name %></span>
              <span class="font-pixel text-xs px-2 py-1 <%= result == :win ? 'text-crt-green' : result == :draw ? 'text-amber' : 'text-red' %>">
                <%= result&.to_s&.upcase || "—" %>
              </span>
            <% end %>
          <% end %>
        <% else %>
          <p class="text-dim font-mono text-xs p-3">Sin resultados todavía.</p>
        <% end %>
      </div>
    </div>

  </div>
</div>
